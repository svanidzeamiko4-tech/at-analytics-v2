# AT Analytics — environment template (copy to .env, never commit .env)
# ACTIVE PHASE: local SQLite only — see docs/LOCAL_SQLITE_ARCHITECTURE.md
# PostgreSQL / Docker: deferred (do not set USE_POSTGRES=true unless re-approved)

# --- Environment ---
AT_ENV=development
AT_DEBUG=false

# --- Database (SQLite — default for this phase) ---
USE_POSTGRES=false
AT_ANALYTICS_DB=amiko_v3.db
AT_AUTH_DB=phase_2_dashboard/auth/at_auth.db

# --- PostgreSQL (inactive — future scale-up only) ---
# DATABASE_URL=postgresql+psycopg2://at_user:CHANGE_ME@localhost:5432/at_analytics
# POSTGRES_USER=at_user
# POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_DB=at_analytics

# --- Auth ---
AT_AUTH_SECRET=change-me-in-production
AT_MANAGER_PASSWORD=manager
AT_DISTRIBUTOR_PASSWORD=distributor

# --- Anthropic AI (Phase 3: Haiku + prompt caching + streaming) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# --- RS.GE sync (Phase 2 worker) ---
RS_GE_USE_MOCK=true
RS_GE_USERNAME=
RS_GE_PASSWORD=
RS_GE_SOAP_URL=
RS_GE_COMPANY_CODE=
RS_SYNC_INTERVAL_MINUTES=30
# Worker log file (separate process: python -m workers.rs_ge_worker)
RS_GE_WORKER_LOG=logs/rs_ge_worker.log

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Docker / nginx (deferred) ---
# HTTP_PORT=80
# HTTPS_PORT=443
